#!/usr/bin/env bash
set -euo pipefail

# dev вЂ” idpishield developer toolkit
# Usage: dev [command]    Run a command directly
#        dev              Show help

cd "$(dirname "$0")"

BOLD=$'\033[1m'
ACCENT=$'\033[38;2;251;191;36m'
MUTED=$'\033[38;2;90;100;128m'
SUCCESS=$'\033[38;2;0;229;204m'
ERROR=$'\033[38;2;230;57;70m'
NC=$'\033[0m'

# в”Ђв”Ђ Commands в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
COMMANDS=(
  "build:рџ“¦:Build binary"
  "check:вњ…:All checks (format, vet, build, lint)"
  "test:рџ§Є:Run tests"
  "doctor:рџ©є:Setup dev environment"
  "fmt:вњЁ:Format code"
  "vet:рџ”¬:Run go vet"
  "lint:рџ”Ќ:Run golangci-lint"
  "coverage:рџ“Љ:Run tests with coverage"
  "benchmark:рџЏ‹:Run benchmarks"
)

show_help() {
  echo ""
  echo "  ${ACCENT}${BOLD}рџ›ЎпёЏ  idpishield Dev${NC}"
  echo ""
  for cmd in "${COMMANDS[@]}"; do
    IFS=':' read -r name emoji desc <<< "$cmd"
    printf "  ${SUCCESS}%s${NC} ${BOLD}%-12s${NC} ${MUTED}%s${NC}\n" "$emoji" "$name" "$desc"
  done
  echo ""
  echo "  ${MUTED}Usage: ./dev [command]${NC}"
  echo ""
}

run_command() {
  local target="$1"

  echo ""

  case "$target" in
    "build")
      echo "  ${ACCENT}${BOLD}рџ“¦ Building idpishield${NC}"
      echo ""
      go build -o idpishield ./cmd/idpishield
      echo "  ${SUCCESS}вњ“${NC} Built: ./idpishield"
      ;;
    "check")
      exec bash scripts/check.sh
      ;;
    "test")
      exec bash scripts/test.sh
      ;;
    "doctor")
      exec bash scripts/doctor.sh
      ;;
    "fmt")
      echo "  ${ACCENT}${BOLD}вњЁ Formatting code${NC}"
      echo ""
      gofmt -w .
      echo "  ${SUCCESS}вњ“${NC} Formatted"
      ;;
    "vet")
      echo "  ${ACCENT}${BOLD}рџ”¬ Running go vet${NC}"
      echo ""
      go vet ./...
      echo "  ${SUCCESS}вњ“${NC} Vet clean"
      ;;
    "lint")
      echo "  ${ACCENT}${BOLD}рџ”Ќ Running linter${NC}"
      echo ""
      golangci-lint run
      echo "  ${SUCCESS}вњ“${NC} Lint clean"
      ;;
    "coverage")
      echo "  ${ACCENT}${BOLD}рџ“Љ Running tests with coverage${NC}"
      echo ""
      go test ./... -count=1 -coverprofile=coverage.out -covermode=atomic
      go tool cover -func=coverage.out | tail -1
      echo ""
      echo "  ${MUTED}HTML report: go tool cover -html=coverage.out${NC}"
      ;;
    "benchmark")
      echo "  ${ACCENT}${BOLD}рџЏ‹ Running benchmarks${NC}"
      echo ""
      go test ./benchmark/ -count=1 -v
      ;;
    *)
      echo "  ${ERROR}Unknown command: $target${NC}"
      show_help
      exit 1
      ;;
  esac
}

# в”Ђв”Ђ Main в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

if [ $# -gt 0 ]; then
  case "$1" in
    -h|--help|help) show_help; exit 0 ;;
    *) run_command "$1" ;;
  esac
  exit 0
fi

# No args в†’ show help
show_help
